[Unit]
Description=IDS Agent - Intrusion Detection & Alert System
After=network.target nginx.service fail2ban.service
Wants=network-online.target

[Service]
Type=simple
User=ids-agent
Group=ids-agent
WorkingDirectory=/opt/ids-agent
ExecStart=/usr/bin/node src/index.js
Restart=on-failure
RestartSec=5
StartLimitBurst=5
StartLimitIntervalSec=60

# Environment variables — fill in your actual values
Environment="TELEGRAM_BOT_TOKEN=your_token_here"
Environment="TELEGRAM_CHAT_ID=your_chat_id_here"
Environment="ANTHROPIC_API_KEY=your_anthropic_key_here"
Environment="AUTONOMOUS_MODE=false"
Environment="MONITORED_SERVICE=your-app-service-name"
Environment="API_BEARER_TOKEN=your_stats_endpoint_token"
Environment="ALLOWED_COUNTRIES=BR,US"
Environment="IDS_PORT=3001"

# Security hardening
NoNewPrivileges=false
ProtectSystem=strict
ReadWritePaths=/var/log/ids-agent /var/lib/ids-agent
ReadOnlyPaths=/var/log/nginx /var/log/auth.log /var/log/ufw.log /var/log/fail2ban.log

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ids-agent

[Install]
WantedBy=multi-user.target
